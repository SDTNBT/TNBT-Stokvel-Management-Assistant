    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-quill-new": "^3.8.3",
    "react-router": "6.28.0",
    "react-router-dom": "^6.28.0",
